# API 服务地址（后端）
API_BASE_URL=http://127.0.0.1:7878

# 可选：按需单独覆盖服务端/客户端读取值
# NUXT_API_BASE=http://127.0.0.1:7878
# NUXT_PUBLIC_API_BASE=http://127.0.0.1:7878

# 预渲染阶段是否强制请求后端（true/false）
# false: 后端不可达时直接走前端降级数据（默认，构建更稳）
# true: 预渲染时拉取真实后端数据（用于完整 SEO 静态内容）
# NUXT_PRERENDER_FETCH_BACKEND=false

# 可选：在线人数 WebSocket 地址（示例）
# HTTPS 站点请使用 wss://，HTTP 站点可用 ws://
# NUXT_PUBLIC_ONLINE_WS_URL=wss://127.0.0.1:7878/ws/online

# 可选：内容更新 WebSocket 地址（后端推送 content.updated）
# 默认会根据 API_BASE_URL 推导为 /ws/content-updates
# NUXT_PUBLIC_CONTENT_UPDATES_WS_URL=wss://127.0.0.1:7878/ws/content-updates

# 是否启用内容实时同步（true/false）
# NUXT_PUBLIC_CONTENT_SYNC_ENABLED=true

# 站长控制台地址（用于前台导航展示）
# NUXT_PUBLIC_ADMIN_CONSOLE_URL=/admin

# 可选：后台 public-marker 接口完整地址（跨域站长态同步）
# NUXT_PUBLIC_ADMIN_PUBLIC_MARKER_URL=https://nehex-console.example.com/admin-api/auth/public-marker

# 站长可读标记 Cookie 名称（前后端需一致）
# NUXT_ADMIN_MARKER_COOKIE_NAME=nehex_admin_marker

# 管理员会话 Cookie 名称（逗号分隔，按顺序匹配）
# NUXT_ADMIN_SESSION_COOKIE_NAMES=nehex_admin_session,admin_session,nehex_admin_token,admin_token

# 是否启用 footer 在线人数 websocket 功能（TRUE/FALSE）
WEBSOCKET_FUTION=TRUE
